---
/**
 * FloatNav — centered floating pill nav, Figma-toolbar style.
 * Server-rendered HTML + a single inline <script> for scroll hide/reveal.
 * Active state is computed from Astro.url.pathname (no client directives).
 */
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';

function isActive(href: string): boolean {
  if (href === '/') return path === '/' || path === '';
  // For /docs, match /docs and any /docs/* route
  if (href === '/docs') return path === '/docs' || path.startsWith('/docs/');
  return path === href;
}

const items = [
  { type: 'link',    href: '/',          label: 'Home',    key: 'home'    },
  { type: 'link',    href: '/docs',      label: 'Docs',    key: 'docs'    },
  { type: 'link',    href: '/anti-slop', label: 'Gallery', key: 'gallery' },
  { type: 'divider', key: 'div1' },
  { type: 'ext', href: 'https://github.com/educlopez/ui-craft',         label: 'GitHub', key: 'github' },
  { type: 'ext', href: 'https://www.npmjs.com/package/ui-craft-detect', label: 'npm',    key: 'npm'    },
] as const;
---

<nav class="float-nav" aria-label="Quick navigation" data-float-nav>
  <ul class="float-nav-list" role="menubar">
    {items.map((item) => {
      if (item.type === 'divider') {
        return (
          <li class="float-nav-divider" aria-hidden="true" role="separator"></li>
        );
      }

      const active = item.type === 'link' && isActive(item.href);
      const commonClass = ['float-nav-item', active ? 'is-active' : null]
        .filter(Boolean)
        .join(' ');

      if (item.type === 'ext') {
        return (
          <li role="none">
            <a
              class={commonClass}
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={item.label}
              role="menuitem"
              tabindex="0"
            >
              {item.key === 'github' && (
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                  <path d="M9 18c-4.51 2-5-2-7-2"/>
                </svg>
              )}
              {item.key === 'npm' && (
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"/>
                  <path d="M12 22V12"/>
                  <path d="m3.3 7 7.703 4.734a2 2 0 0 0 1.994 0L20.7 7"/>
                  <path d="m7.5 4.27 9 5.15"/>
                </svg>
              )}
            </a>
          </li>
        );
      }

      // Internal link
      return (
        <li role="none">
          <a
            class={commonClass}
            href={item.href}
            aria-label={item.label}
            aria-current={active ? 'page' : undefined}
            role="menuitem"
            tabindex="0"
          >
            {item.key === 'home' && (
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/>
                <path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              </svg>
            )}
            {item.key === 'docs' && (
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
                <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
                <path d="M10 9H8"/>
                <path d="M16 13H8"/>
                <path d="M16 17H8"/>
              </svg>
            )}
            {item.key === 'gallery' && (
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
                <path d="M20 3v4"/>
                <path d="M22 5h-4"/>
                <path d="M4 17v2"/>
                <path d="M5 18H3"/>
              </svg>
            )}
          </a>
        </li>
      );
    })}
  </ul>
</nav>

<style is:global>
  .float-nav {
    position: fixed;
    bottom: calc(24px + env(safe-area-inset-bottom, 0px));
    left: 50%;
    transform: translateX(-50%) translateY(0);
    z-index: 60;
    background: oklch(100% 0 0);
    border: 1px solid oklch(92% 0.005 250 / 0.6);
    border-radius: 12px;
    padding: 8px;
    box-shadow:
      0 2px 6px oklch(15% 0.03 260 / 0.04),
      0 8px 24px oklch(15% 0.03 260 / 0.08),
      0 24px 56px -12px oklch(15% 0.03 260 / 0.12);
    transition:
      transform 200ms var(--ease-out),
      opacity 280ms var(--ease-out);
    will-change: transform;
  }

  /* Hidden state for scroll-hide behavior */
  .float-nav[data-hidden="true"] {
    transform: translateX(-50%) translateY(calc(100% + 32px));
  }

  .float-nav-list {
    display: flex;
    align-items: center;
    gap: 2px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .float-nav-divider {
    width: 1px;
    height: 22px;
    background: oklch(92% 0.005 250);
    margin: 0 6px;
    flex-shrink: 0;
  }

  .float-nav-item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    color: oklch(15% 0 0);
    background: transparent;
    border: 0;
    cursor: pointer;
    text-decoration: none;
    transition:
      background-color 150ms var(--ease-out),
      color 150ms var(--ease-out),
      transform 120ms var(--ease-out);
  }
  .float-nav-item svg {
    display: block;
  }
  .float-nav-item:hover {
    background: oklch(96% 0.003 250);
    color: oklch(15% 0 0);
  }
  .float-nav-item:active {
    transform: scale(0.94);
  }
  .float-nav-item:focus-visible {
    outline: 2px solid var(--color-blue-600);
    outline-offset: 2px;
  }
  .float-nav-item.is-active {
    background: var(--color-blue-600);
    color: oklch(100% 0 0);
    border-radius: 8px;
  }
  .float-nav-item.is-active:hover {
    background: var(--color-blue-600);
    color: oklch(100% 0 0);
  }

  /* Mobile tweaks */
  @media (max-width: 480px) {
    .float-nav {
      bottom: calc(12px + env(safe-area-inset-bottom, 0px));
      padding: 6px;
    }
    .float-nav-list {
      gap: 1px;
    }
    .float-nav-item {
      width: 36px;
      height: 36px;
    }
    .float-nav-divider {
      height: 20px;
      margin: 0 4px;
    }
  }

  /* Reduced motion: always visible, no transforms */
  @media (prefers-reduced-motion: reduce) {
    .float-nav,
    .float-nav-item {
      transition: none;
    }
    .float-nav[data-hidden="true"] {
      transform: translateX(-50%) translateY(0);
    }
  }
</style>

<script>
  (() => {
    const nav = document.querySelector('[data-float-nav]') as HTMLElement | null;
    if (!nav) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return; // Leave it always-visible, no listeners.

    // Scroll hide / reveal with rAF throttling.
    let lastY = window.scrollY;
    let ticking = false;
    const THRESHOLD = 6; // ignore tiny deltas

    const update = () => {
      const y = window.scrollY;
      const dy = y - lastY;
      if (Math.abs(dy) > THRESHOLD) {
        if (dy > 0 && y > 120) {
          // scrolling down — hide
          nav.setAttribute('data-hidden', 'true');
        } else {
          nav.setAttribute('data-hidden', 'false');
        }
        lastY = y;
      }
      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });

    // Keyboard: arrow-key navigation between items, Escape defocuses.
    const items = Array.from(nav.querySelectorAll<HTMLAnchorElement>('.float-nav-item'));
    nav.addEventListener('keydown', (e) => {
      const ke = e as KeyboardEvent;
      const target = document.activeElement as HTMLElement | null;
      if (!target || !items.includes(target as HTMLAnchorElement)) return;
      const idx = items.indexOf(target as HTMLAnchorElement);
      if (ke.key === 'ArrowRight' || ke.key === 'ArrowDown') {
        ke.preventDefault();
        items[(idx + 1) % items.length].focus();
      } else if (ke.key === 'ArrowLeft' || ke.key === 'ArrowUp') {
        ke.preventDefault();
        items[(idx - 1 + items.length) % items.length].focus();
      } else if (ke.key === 'Home') {
        ke.preventDefault();
        items[0].focus();
      } else if (ke.key === 'End') {
        ke.preventDefault();
        items[items.length - 1].focus();
      } else if (ke.key === 'Escape') {
        (target as HTMLElement).blur();
      }
    });
  })();
</script>
