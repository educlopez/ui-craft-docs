    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>

    <script>
      // GitHub stars: 1h localStorage cache, hide gracefully on failure
      (function () {
        const el = document.querySelector('.stars-count');
        if (!el) return;
        const KEY = 'uicraft.stars.v1';
        const TTL = 60 * 60 * 1000;
        const render = (n) => {
          if (typeof n === 'number' && Number.isFinite(n)) {
            el.textContent = n.toLocaleString();
          } else {
            el.textContent = '';
            el.setAttribute('hidden', '');
          }
        };
        try {
          const raw = localStorage.getItem(KEY);
          if (raw) {
            const { n, t } = JSON.parse(raw);
            if (Date.now() - t < TTL) { render(n); return; }
          }
        } catch {}
        // Empty (n == null) and error (HTTP non-ok, parse, network) both route to render(null), hiding the badge.
        // ui-craft-detect-ignore-next-line rule: state/missing-empty-or-error
        fetch('https://api.github.com/repos/educlopez/ui-craft')
          .then(r => r.ok ? r.json() : Promise.reject(new Error('http ' + r.status)))
          .then(d => {
            const n = d && typeof d.stargazers_count === 'number' ? d.stargazers_count : null;
            if (n == null) { render(null); return; }
            render(n);
            try { localStorage.setItem(KEY, JSON.stringify({ n, t: Date.now() })); } catch {}
          })
          .catch(() => render(null));
      })();

      // Copy buttons: icon swap is pure CSS via [data-copied]; setTimeout only resets the attribute
      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', function () {
          const cmd = this.getAttribute('data-command');
          navigator.clipboard.writeText(cmd).then(() => {
            this.setAttribute('data-copied', '');
            // ui-craft-detect-ignore-next-line rule: perf/setTimeout-animation
            setTimeout(() => { this.removeAttribute('data-copied'); }, 2000);
          });
        });
      });

      const tabs = document.querySelectorAll('.tab');
      const comparisons = document.querySelectorAll('.comparison[data-comparison]');
      tabs.forEach(tab => {
        tab.addEventListener('click', function () {
          const target = this.getAttribute('data-tab');
          tabs.forEach(t => t.classList.remove('active'));
          this.classList.add('active');
          comparisons.forEach(c => {
            if (c.getAttribute('data-comparison') === target) {
              c.classList.add('active');
            } else { c.classList.remove('active'); }
          });
        });
      });

      document.querySelectorAll('.comparison-slider').forEach(slider => {
        const beforeImg = slider.querySelector('.slider-before');
        const handle = slider.querySelector('.slider-handle');
        let isDragging = false;
        function setPosition(pct) {
          const c = Math.max(0, Math.min(100, pct));
          const right = 100 - c;
          beforeImg.style.clipPath = `inset(0 ${right}% 0 0)`;
          handle.style.left = c + '%';
          slider.setAttribute('aria-valuenow', Math.round(c));
        }
        function getPct(x) { const r = slider.getBoundingClientRect(); return ((x - r.left) / r.width) * 100; }
        slider.addEventListener('pointerdown', e => { isDragging = true; slider.setPointerCapture(e.pointerId); setPosition(getPct(e.clientX)); });
        slider.addEventListener('pointermove', e => { if (isDragging) setPosition(getPct(e.clientX)); });
        slider.addEventListener('pointerup', () => { isDragging = false; });
        slider.addEventListener('pointercancel', () => { isDragging = false; });
        slider.addEventListener('keydown', e => {
          const cur = parseFloat(slider.getAttribute('aria-valuenow')) || 50;
          if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') { e.preventDefault(); setPosition(cur - 2); }
          else if (e.key === 'ArrowRight' || e.key === 'ArrowUp') { e.preventDefault(); setPosition(cur + 2); }
        });
      });

      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const seen = new Set();
        const obs = new IntersectionObserver(entries => {
          entries.forEach(e => {
            if (!e.isIntersecting || seen.has(e.target)) return;
            seen.add(e.target);
            const parent = e.target.parentElement;
            const sibs = parent ? [...parent.querySelectorAll(':scope > [data-reveal]')] : [];
            const idx = sibs.indexOf(e.target);
            e.target.style.transitionDelay = `${idx > 0 ? idx * 50 : 0}ms`;
            e.target.classList.add('is-visible');
            obs.unobserve(e.target);
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
        document.querySelectorAll('[data-reveal]').forEach(el => obs.observe(el));
      } else {
        document.querySelectorAll('[data-reveal]').forEach(el => { el.style.opacity = '1'; el.style.transform = 'none'; });
      }

      // Figma rulers
      function buildRulers() {
        const rulerH = document.getElementById('ruler-h');
        const rulerV = document.getElementById('ruler-v');
        if (!rulerH || !rulerV) return;
        if (window.innerWidth < 768) return;

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReducedMotion) return;

        // Horizontal
        const hWidth = Math.max(window.innerWidth, 1920);
        let hHTML = '';
        for (let x = 0; x <= hWidth; x += 50) {
          const isMajor = x % 250 === 0;
          hHTML += '<div class="ruler-tick ' + (isMajor ? 'ruler-tick--major' : 'ruler-tick--minor') + '" style="left:' + x + 'px"></div>';
          if (isMajor) {
            hHTML += '<span class="ruler-label" style="left:' + x + 'px">' + x + '</span>';
          }
        }
        rulerH.innerHTML = hHTML;

        // Vertical — inner container that we translate on scroll
        const pageHeight = document.documentElement.scrollHeight + 500;
        let vHTML = '<div class="ruler-v-inner" style="position:absolute;top:0;left:0;right:0;">';
        for (let y = 0; y <= pageHeight; y += 50) {
          const isMajor = y % 250 === 0;
          vHTML += '<div class="ruler-tick ' + (isMajor ? 'ruler-tick--major' : 'ruler-tick--minor') + '" style="top:' + y + 'px"></div>';
          if (isMajor) {
            vHTML += '<span class="ruler-label" style="top:' + y + 'px">' + y + '</span>';
          }
        }
        vHTML += '</div>';
        rulerV.innerHTML = vHTML;
        onRulerScroll();
      }

      function onRulerScroll() {
        const inner = document.querySelector('.ruler-v-inner');
        if (inner) {
          inner.style.transform = 'translateY(' + (-window.scrollY) + 'px)';
        }
      }

      buildRulers();
      window.addEventListener('scroll', onRulerScroll, { passive: true });
      window.addEventListener('resize', buildRulers, { passive: true });

      // Draggable guides
      (function () {
        if (window.innerWidth < 768) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const rulerH = document.getElementById('ruler-h');
        const rulerV = document.getElementById('ruler-v');
        if (!rulerH || !rulerV) return;

        const guides = [];
        let dragState = null;
        let label = null;
        let raf = 0;

        function createLabel() {
          const el = document.createElement('div');
          el.className = 'guide-label';
          document.body.appendChild(el);
          return el;
        }

        function showLabel(x, y, text, type) {
          if (!label) label = createLabel();
          label.textContent = text;
          label.style.display = '';
          if (type === 'h') {
            label.style.left = (x + 10) + 'px';
            label.style.top = (y - 18) + 'px';
          } else {
            label.style.left = (x + 10) + 'px';
            label.style.top = (y - 18) + 'px';
          }
        }

        function hideLabel() {
          if (label) label.style.display = 'none';
        }

        function createGuide(type, pos) {
          const el = document.createElement('div');
          el.className = 'dragged-guide dragged-guide--' + type;
          if (type === 'h') {
            el.style.top = pos + 'px';
          } else {
            el.style.left = pos + 'px';
          }
          document.body.appendChild(el);

          const guide = { el, type, pos };
          guides.push(guide);

          el.addEventListener('pointerdown', function (e) {
            e.preventDefault();
            startGuideDrag(guide, e);
          });

          return guide;
        }

        function spawnPoof(x, y) {
          const cloud = document.createElement('div');
          cloud.className = 'poof-cloud';
          const count = 10;
          for (let i = 0; i < count; i++) {
            const angle = (Math.PI * 2 * i) / count + (Math.random() - 0.5) * 0.6;
            const dist = 22 + Math.random() * 30;
            const endDist = dist + 16 + Math.random() * 20;
            const size = 10 + Math.random() * 16;
            const p = document.createElement('div');
            p.className = 'poof-particle';
            p.style.width = size + 'px';
            p.style.height = size + 'px';
            p.style.left = x + 'px';
            p.style.top = y + 'px';
            p.style.setProperty('--px', '0px');
            p.style.setProperty('--py', '0px');
            p.style.setProperty('--tx', Math.cos(angle) * dist + 'px');
            p.style.setProperty('--ty', Math.sin(angle) * dist + 'px');
            p.style.setProperty('--ex', Math.cos(angle) * endDist + 'px');
            p.style.setProperty('--ey', Math.sin(angle) * endDist + 'px');
            p.style.animationDelay = (Math.random() * 60) + 'ms';
            cloud.appendChild(p);
          }
          document.body.appendChild(cloud);
          setTimeout(() => cloud.remove(), 600);
        }

        function removeGuide(guide, poofX, poofY) {
          const idx = guides.indexOf(guide);
          if (idx > -1) guides.splice(idx, 1);

          if (poofX != null && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            const px = guide.type === 'h' ? poofX : 30;
            const py = guide.type === 'v' ? poofY : 30;
            spawnPoof(px, py);
          }
          guide.el.remove();
        }

        function startGuideDrag(guide, e) {
          dragState = { guide, isNew: false };
          document.body.classList.add('guide-dragging--' + guide.type);
          updateDrag(e.clientX, e.clientY);
        }

        var lastMouse = { x: 0, y: 0 };

        function updateDrag(clientX, clientY) {
          lastMouse.x = clientX;
          lastMouse.y = clientY;
          cancelAnimationFrame(raf);
          raf = requestAnimationFrame(function () {
            if (!dragState) return;
            const g = dragState.guide;
            if (g.type === 'h') {
              g.pos = clientY;
              g.el.style.top = clientY + 'px';
              showLabel(clientX, clientY, Math.round(clientY + window.scrollY) + 'px', 'h');
            } else {
              g.pos = clientX;
              g.el.style.left = clientX + 'px';
              showLabel(clientX, clientY, Math.round(clientX) + 'px', 'v');
            }
          });
        }

        function endDrag() {
          if (!dragState) return;
          const g = dragState.guide;
          const onRuler = (g.type === 'h' && g.pos <= 24) || (g.type === 'v' && g.pos <= 24);
          if (onRuler) removeGuide(g, lastMouse.x, lastMouse.y);
          document.body.classList.remove('guide-dragging--h', 'guide-dragging--v');
          hideLabel();
          dragState = null;
        }

        rulerH.addEventListener('pointerdown', function (e) {
          if (e.button !== 0) return;
          e.preventDefault();
          const guide = createGuide('h', e.clientY);
          dragState = { guide, isNew: true };
          document.body.classList.add('guide-dragging--h');
          updateDrag(e.clientX, e.clientY);
        });

        rulerV.addEventListener('pointerdown', function (e) {
          if (e.button !== 0) return;
          e.preventDefault();
          const guide = createGuide('v', e.clientX);
          dragState = { guide, isNew: true };
          document.body.classList.add('guide-dragging--v');
          updateDrag(e.clientX, e.clientY);
        });

        document.addEventListener('pointermove', function (e) {
          if (dragState) updateDrag(e.clientX, e.clientY);
        });

        document.addEventListener('pointerup', endDrag);
        document.addEventListener('pointercancel', endDrag);
      })();

      // Footer brand inspect effect
      (function () {
        const wrap = document.getElementById('brand-inspect');
        const brand = document.getElementById('footer-brand');
        const overlay = document.getElementById('inspect-overlay');
        const cursorEl = document.getElementById('inspect-cursor');
        const crossH = document.getElementById('inspect-ch');
        const crossV = document.getElementById('inspect-cv');
        const wLabel = document.getElementById('inspect-w');
        const hLabel = document.getElementById('inspect-h');
        if (!wrap || !brand || !overlay || window.innerWidth < 768) return;

        wrap.addEventListener('mouseenter', function () {
          const r = brand.getBoundingClientRect();
          wLabel.textContent = Math.round(r.width) + 'px';
          hLabel.textContent = Math.round(r.height) + 'px';
          overlay.classList.add('is-visible');
          crossH.classList.add('is-visible');
          crossV.classList.add('is-visible');
        });

        wrap.addEventListener('mousemove', function (e) {
          const r = brand.getBoundingClientRect();
          const localX = e.clientX - r.left;
          const localY = e.clientY - r.top;
          const x = Math.round(localX);
          const y = Math.round(localY);
          cursorEl.style.left = localX + 'px';
          cursorEl.style.top = localY + 'px';
          cursorEl.textContent = x + ', ' + y;
          crossH.style.top = e.clientY + 'px';
          crossV.style.left = e.clientX + 'px';
        });

        wrap.addEventListener('mouseleave', function () {
          overlay.classList.remove('is-visible');
          crossH.classList.remove('is-visible');
          crossV.classList.remove('is-visible');
        });
      })();

      // Footer year
      const yearEl = document.querySelector('.footer-year');
      if (yearEl) yearEl.textContent = new Date().getFullYear();
    </script>

    <!-- Minimal slider CSS that can't be expressed with Tailwind utilities -->
    <style>
      /* Comparison tabs */
      .comp-tabs .tab {
        font-size: 12px;
        font-weight: 500;
        padding: 6px 14px;
        border-radius: 6px;
        background: transparent;
        color: var(--color-text-secondary);
        cursor: pointer;
        touch-action: manipulation;
        transition: background-color 0.2s var(--ease-out), color 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out);
      }
      .comp-tabs .tab:focus-visible {
        outline: 2px solid var(--color-blue-600);
        outline-offset: 2px;
      }
      .comp-tabs .tab.active {
        background: var(--color-blue-600);
        color: white;
        box-shadow: 0 1px 3px oklch(0.458 0.305 268.13 / 0.3);
      }
      @media (hover: hover) and (pointer: fine) {
        .comp-tabs .tab:not(.active):hover {
          background: oklch(93% 0.002 250);
          color: var(--color-text);
        }
        .comp-tabs .tab.active:hover {
          background: oklch(0.4 0.28 268.13);
        }
      }

      .comparison { display: none; }
      .comparison.active { display: block; }

      .comparison-slider {
        position: relative;
        overflow: hidden;
        border-radius: 0.75rem;
        border: 1px solid var(--color-border);
        cursor: ew-resize;
        touch-action: none;
        user-select: none;
        -webkit-user-select: none;
        box-shadow: 0 1px 3px oklch(0% 0 0 / 0.06), 0 8px 24px oklch(0% 0 0 / 0.06);
      }
      .comparison-slider:focus-visible {
        outline: 2px solid var(--color-blue-600);
        outline-offset: 3px;
      }

      .slider-after,
      .slider-before {
        display: block;
        width: 100%;
        height: auto;
        -webkit-user-drag: none;
        pointer-events: none;
      }
      .slider-before {
        position: absolute;
        top: 0;
        left: 0;
        z-index: 1;
        clip-path: inset(0 50% 0 0);
      }

      .slider-handle {
        position: absolute;
        top: 0;
        bottom: 0;
        left: 50%;
        width: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2;
        pointer-events: none;
      }
      .slider-handle-line {
        position: absolute;
        top: 0;
        bottom: 0;
        left: 0;
        width: 2px;
        margin-left: -1px;
        background: oklch(0.458 0.305 268.13);
        box-shadow: 0 0 8px oklch(0.458 0.305 268.13 / 0.3);
      }
      .slider-handle-grip {
        position: relative;
        width: 36px;
        height: 36px;
        flex-shrink: 0;
        border-radius: 50%;
        background: oklch(0.458 0.305 268.13);
        border: 2px solid white;
        box-shadow: 0 2px 8px oklch(0.458 0.305 268.13 / 0.3), 0 0 0 4px oklch(0.458 0.305 268.13 / 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        transition: transform 0.15s var(--ease-out), box-shadow 0.15s var(--ease-out);
      }
      .comparison-slider:active .slider-handle-grip {
        transform: scale(1.1);
        box-shadow: 0 2px 12px oklch(0.458 0.305 268.13 / 0.4), 0 0 0 6px oklch(0.458 0.305 268.13 / 0.12);
      }

      /* Copy button: pure-CSS icon swap on [data-copied] (no DOM mutation) */
      .copy-btn .copy-icon {
        position: absolute;
        inset: 0;
        margin: auto;
        transition: opacity 180ms var(--ease-out), transform 180ms var(--ease-out);
      }
      .copy-btn .copy-icon.check {
        opacity: 0;
        transform: scale(0.85);
        color: oklch(62% 0.16 150);
      }
      .copy-btn[data-copied] { color: oklch(62% 0.16 150); }
      .copy-btn[data-copied] .copy-icon.copy {
        opacity: 0;
        transform: scale(0.85);
      }
      .copy-btn[data-copied] .copy-icon.check {
        opacity: 1;
        transform: scale(1);
      }
      @media (prefers-reduced-motion: reduce) {
        .copy-btn .copy-icon { transition: none; }
      }

      /* Aren easter egg — speech bubble */
      .aren-bubble {
        position: absolute;
        top: 50%;
        left: calc(100% + 16px);
        transform: translateY(-50%) translateX(-4px);
        white-space: nowrap;
        font-size: 13px;
        font-weight: 500;
        letter-spacing: -0.01em;
        color: var(--color-text);
        background: white;
        border: 1px solid oklch(92% 0.005 250);
        border-radius: 10px;
        padding: 6px 11px;
        box-shadow: 0 1px 2px oklch(0% 0 0 / 0.06), 0 4px 12px oklch(0% 0 0 / 0.05);
        opacity: 0;
        pointer-events: none;
        transition: opacity 180ms var(--ease-out), transform 180ms var(--ease-out);
      }
      /* Tail — border layer */
      .aren-bubble::before {
        content: '';
        position: absolute;
        top: 50%;
        right: 100%;
        transform: translateY(-50%);
        border: 5px solid transparent;
        border-right-color: oklch(92% 0.005 250);
      }
      /* Tail — fill layer */
      .aren-bubble::after {
        content: '';
        position: absolute;
        top: 50%;
        right: 100%;
        transform: translateY(-50%);
        border: 4px solid transparent;
        border-right-color: white;
        margin-right: -1px;
      }
      @media (hover: hover) and (pointer: fine) {
        .aren-egg:hover .aren-bubble {
          opacity: 1;
          transform: translateY(-50%) translateX(0);
        }

        /* Mode cards hover */
        .mode-card {
          transition: transform 200ms var(--ease-out);
        }
        .mode-card:hover {
          transform: translateY(-1px);
        }

        /* Domain chip hover — subtle lift */
        .domain-chips code {
          transition: background-color 200ms var(--ease-out), border-color 200ms var(--ease-out);
        }
        .domain-chips li:hover code {
          background-color: oklch(94% 0.003 250);
          border-color: oklch(88% 0.005 250);
        }
      }

      /* Anti-slop demo — one heroic crossed-out anti-pattern */
      .slop-figure { position: relative; }
      .slop-demo {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 18px 8px;
      }
      .slop-demo-btn {
        /* Deliberately loud — the exact pattern the skill rejects */
        font-family: var(--font-body);
        font-weight: 500;
        font-size: 15px;
        color: white;
        padding: 12px 24px;
        border-radius: 9999px;
        border: 0;
        background: linear-gradient(135deg, oklch(0.55 0.28 300) 0%, oklch(0.75 0.18 220) 100%);
        box-shadow:
          0 0 22px oklch(0.6 0.25 280 / 0.45),
