      [data-craft="off"] .glass-card .glass-craft-meta,
      [data-craft="off"] .glass-card .glass-craft-body,
      [data-craft="off"] .glass-card .glass-craft-stats,
      [data-craft="off"] .glass-card .glass-craft-foot {
        color: rgba(255, 255, 255, 0.75);
      }
      [data-craft="off"] .glass-card .glass-craft-stats .tnum,
      [data-craft="off"] .glass-card .glass-craft-foot .tnum {
        color: rgba(255, 255, 255, 0.95);
      }
      [data-craft="off"] .glass-card .glass-craft-divider {
        background: rgba(255, 255, 255, 0.15);
      }
      [data-craft="off"] .glass-card .glass-craft-sep {
        color: rgba(255, 255, 255, 0.4);
      }
      [data-craft="off"] .glass-card .avatar-img {
        border-color: rgba(255, 255, 255, 0.25);
        box-shadow: 0 0 18px rgba(6, 182, 212, 0.5);
      }

      /* CRAFT: flat white card with accent hairline anchor */
      [data-craft="on"] .glass-card {
        background: oklch(100% 0 0);
        border: 1px solid oklch(92% 0.005 250);
        border-radius: 12px;
        box-shadow:
          0 1px 2px oklch(15% 0.03 260 / 0.06),
          0 4px 12px oklch(15% 0.03 260 / 0.05),
          0 16px 40px -12px oklch(15% 0.03 260 / 0.08);
