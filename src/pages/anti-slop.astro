      }
      .glass-craft-stats .tnum { font-variant-numeric: tabular-nums; color: var(--color-text); font-weight: 500; }
      .glass-craft-divider {
        height: 1px;
        background: oklch(92% 0.005 250);
        margin: 2px 0;
      }
      .glass-craft-foot {
        font-size: 10.5px;
        color: oklch(60% 0.005 250);
        font-family: var(--font-mono);
        line-height: 1.5;
      }
      .glass-craft-foot .tnum { font-variant-numeric: tabular-nums; }

      /* ============================================================
         06 · Blobs
         ============================================================ */
      .blob-stage { padding: 0; }
      .blob {
        position: absolute;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        filter: blur(40px);
        pointer-events: none;
      }
      .blob--pink {
        top: -40px;
        left: -40px;
        background: radial-gradient(circle at 30% 30%, #ec4899 0%, transparent 60%);
        animation: blob-bounce 5s ease-in-out infinite;
      }
      .blob--blue {
        bottom: -40px;
        right: -40px;
        background: radial-gradient(circle at 70% 70%, #3b82f6 0%, transparent 60%);
        animation: blob-bounce 6s ease-in-out infinite reverse;
      }
      [data-craft="on"] .blob { opacity: 0; animation: none; }

      @keyframes blob-bounce {
        0%, 100% { transform: translate(0, 0) scale(1); }
        50%      { transform: translate(12px, -12px) scale(1.05); }
      }

      .blob-content {
        position: relative;
        z-index: 1;
        padding: 28px 24px;
        width: 100%;
        max-width: 420px;
        text-align: center;
      }
      .blob-rule {
        display: block;
        width: 40px;
        height: 1px;
        background: var(--color-border);
        margin: 0 auto 16px;
      }
      [data-craft="off"] .blob-rule { display: none; }
      .blob-eyebrow {
        font-size: 11px;
        font-family: var(--font-mono);
        color: var(--color-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 6px;
      }
      .blob-title {
        font-size: 22px;
        font-weight: 500;
        color: var(--color-text);
        letter-spacing: -0.018em;
        line-height: 1.18;
      }
      .blob-sub {
        font-size: 13px;
        color: var(--color-text-secondary);
        margin-top: 10px;
        line-height: 1.55;
      }
      /* CRAFT: editorial whitespace */
      [data-craft="on"] .blob-stage { border-top: 1px solid oklch(92% 0.005 250); }
      [data-craft="on"] .blob-content {
        text-align: left;
        max-width: 65ch;
        padding: 32px 28px;
      }
      [data-craft="on"] .blob-rule { margin: 0 0 16px; }
      [data-craft="on"] .blob-title {
        text-wrap: balance;
        max-width: 20ch;
      }
      [data-craft="on"] .blob-quote {
        display: block;
        font-size: 14.5px;
        line-height: 1.6;
        color: var(--color-text);
        text-wrap: pretty;
        max-width: 52ch;
        margin-top: 14px;
      }
      [data-craft="on"] .blob-quote::first-letter {
        font-size: 2.5em;
        float: left;
        line-height: 0.95;
        font-weight: 500;
        color: var(--color-text);
        padding: 2px 8px 0 0;
        margin-top: 2px;
      }

      /* ============================================================
         07 · Trend pill — Dub-style KPI card
         ============================================================ */

      /* SLOP: gradient text + emoji pill + chip row */
      .kpi-slop {
        width: 85%;
        max-width: 380px;
        padding: 16px 18px;
        border: 1px solid #fbcfe8;
        border-radius: 14px;
        background: linear-gradient(135deg, #fff1f7 0%, #f3e8ff 100%);
        box-shadow: 0 4px 18px rgba(236, 72, 153, 0.12);
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .kpi-slop-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
      }
      .kpi-slop-label {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #a21caf;
      }
      .kpi-slop-badge {
        font-size: 12px;
        font-weight: 700;
        color: white;
        background: #10b981;
        padding: 4px 10px;
        border-radius: 999px;
        box-shadow: 0 0 16px rgba(16, 185, 129, 0.45);
      }
      .kpi-slop-value {
        font-size: 40px;
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: -0.02em;
        background: linear-gradient(90deg, #ec4899 0%, #8b5cf6 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
        font-variant-numeric: tabular-nums;
      }
      .kpi-slop-context {
        font-size: 12px;
        color: #a21caf;
        font-weight: 600;
        letter-spacing: 0.02em;
      }

      /* CRAFT: restrained KPI card with embedded sparkline */
      .kpi-card {
        width: 88%;
        max-width: 420px;
        padding: 16px 18px;
        border: 1px solid oklch(92% 0.005 250);
        border-radius: 10px;
        background: var(--color-bg);
        box-shadow:
          0 1px 2px oklch(20% 0.02 250 / 0.04),
          0 4px 14px -4px oklch(20% 0.02 250 / 0.06);
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .kpi-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
      }
      .kpi-label {
        font-size: 11px;
        color: var(--color-text-secondary);
        font-family: var(--font-mono);
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .kpi-filter {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-family: var(--font-mono);
        color: var(--color-text-secondary);
        background: transparent;
        border: 1px solid oklch(92% 0.005 250);
        border-radius: 6px;
        padding: 3px 8px;
        cursor: default;
      }
      .kpi-filter svg { opacity: 0.7; }
      .kpi-body {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 12px;
      }
      .kpi-value {
        font-size: clamp(30px, 4.5vw, 40px);
        font-weight: 500;
        line-height: 1;
        color: var(--color-text);
        font-variant-numeric: tabular-nums;
        font-feature-settings: "ss01", "tnum";
        letter-spacing: -0.03em;
      }
      .kpi-spark { color: oklch(62% 0.15 250); flex-shrink: 0; margin-right: 4px; }
      .kpi-trend {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12.5px;
      }
      .trend-triangle { color: oklch(52% 0.13 155); flex-shrink: 0; }
      .kpi-trend-pct { color: oklch(52% 0.13 155); font-weight: 500; font-variant-numeric: tabular-nums; }
      .kpi-trend-context { color: var(--color-text-secondary); }
      .kpi-divider {
        height: 1px;
        background: oklch(94% 0.005 250);
      }
      .kpi-foot {
        font-size: 11px;
        color: oklch(60% 0.005 250);
        font-family: var(--font-mono);
      }
      .kpi-foot .tnum { font-variant-numeric: tabular-nums; }

      /* ============================================================
         08 · Loader
         ============================================================ */
      .loader-stage { }
      .loader-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 18px;
        width: 100%;
      }
      .loading-for {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--color-text-secondary);
        letter-spacing: 0.04em;
      }

      /* SLOP: bigger spinner + caps + dots + subtext */
      .slop-loader {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 18px;
        padding: 8px 0;
      }
      .spinner-ring {
        width: 68px;
        height: 68px;
        border-radius: 50%;
        background:
          conic-gradient(from 0deg, #8b5cf6, #06b6d4, #ec4899, #8b5cf6);
        mask: radial-gradient(circle 26px at center, transparent 99%, #000 100%);
        -webkit-mask: radial-gradient(circle 26px at center, transparent 99%, #000 100%);
        animation: spin 1s linear infinite;
      }
      .loader-caps {
        font-family: var(--font-mono);
        font-size: 16px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--color-text);
      }
      .dots {
        display: inline-flex;
        gap: 4px;
        margin-left: 6px;
      }
      .dots span {
        animation: dot-bounce 1.1s ease-in-out infinite;
        display: inline-block;
      }
      .dots span:nth-child(2) { animation-delay: 0.15s; }
      .dots span:nth-child(3) { animation-delay: 0.3s; }
      .slop-subtext {
        font-size: 12px;
        color: var(--color-text-secondary);
        letter-spacing: 0.02em;
        animation: slop-fade 2.2s ease-in-out infinite;
      }

      @keyframes spin { to { transform: rotate(360deg); } }
      @keyframes dot-bounce {
        0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
        40%           { transform: translateY(-5px); opacity: 1; }
      }
      @keyframes slop-fade {
        0%, 100% { opacity: 0.4; }
        50%      { opacity: 1; }
      }

      /* CRAFT: multi-row skeleton matching article/post card shape */
      .craft-skeleton {
        display: flex;
        flex-direction: column;
        gap: 12px;
        width: 90%;
        max-width: 360px;
      }
      .sk-row-head { display: flex; align-items: center; gap: 12px; }
      .sk-stack { display: flex; flex-direction: column; gap: 6px; flex: 1; min-width: 0; }
      .sk-body { display: flex; flex-direction: column; gap: 6px; }
      .sk-actions { display: flex; gap: 8px; margin-top: 2px; }
      .sk {
        background: var(--color-code-bg);
        border-radius: 4px;
        position: relative;
        overflow: hidden;
      }
      .sk::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(
          90deg,
          transparent 0%,
          oklch(97% 0.003 250 / 0.9) 50%,
          transparent 100%
        );
        animation: shimmer 1.5s linear infinite;
      }
      @keyframes shimmer {
        from { transform: translateX(-100%); }
        to   { transform: translateX(100%); }
      }
      .sk-line { height: 12px; }
      .sk-name { height: 14px; width: 45%; }
      .sk-meta { height: 10px; width: 30%; }
      .sk-title-bar { height: 18px; width: 70%; border-radius: 5px; }
      .sk-body-line { height: 12px; width: 100%; }
      .sk-body-line:last-child { width: 92%; }
      .sk-avatar { width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0; }
      .sk-pill { height: 22px; width: 60px; border-radius: 999px; }

      /* ============================================================
         Footer CTA
         ============================================================ */
      .page-cta .inline-code {
        font-family: var(--font-mono);
        font-size: 0.85em;
        padding: 0.1em 0.35em;
        background: var(--color-code-bg);
        border-radius: 4px;
        color: var(--color-text);
      }
      .cmd-chip {
        font-family: var(--font-mono);
        font-size: 12.5px;
        background: var(--color-code-bg);
        border: 1px solid var(--color-border);
        padding: 7px 11px;
        border-radius: 6px;
        color: var(--color-text);
      }

      /* ============================================================
         Reduced motion
         ============================================================ */
      @media (prefers-reduced-motion: reduce) {
        .demo-btn-01,
        .mini-card,
        .demo-h2,
        .metric-big,
        .glass-card,
        .glass-bg,
        .blob,
        .blob-content,
        .kpi-slop,
        .kpi-card,
        .slop-loader,
        .craft-skeleton,
        .craft-toggle-track,
        .craft-toggle-thumb {
          transition-duration: 0.01ms !important;
          transition-delay: 0ms !important;
        }
        .blob, .spinner-ring, .dots span, .sk::after, .slop-subtext {
          animation: none !important;
        }
      }
    </style>

    <script>
      const root = document.body;
      const btn = document.querySelector('.craft-toggle') as HTMLButtonElement | null;
      const fixedStat = document.querySelector('[data-fixed]') as HTMLElement | null;

      function setState(next: 'off' | 'on') {
        root.dataset.craft = next;
        btn?.setAttribute('aria-pressed', next === 'on' ? 'true' : 'false');
        if (fixedStat) fixedStat.textContent = next === 'on' ? '8' : '0';
      }

      function toggle() {
        const current = (root.dataset.craft ?? 'off') as 'off' | 'on';
        setState(current === 'off' ? 'on' : 'off');
      }

      if (btn) {
        btn.addEventListener('click', toggle);
        btn.addEventListener('keydown', (e) => {
          if (e.key === ' ' || e.key === 'Enter') {
            e.preventDefault();
            toggle();
          }
        });
      }
    </script>

    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>

    <FloatNav />
  </body>
</html>
