---
/* ui-craft-detect-ignore-file — this page intentionally demonstrates anti-patterns for educational purposes. The "slop" states use the anti-patterns the skill is designed to reject (gradients, glow, bounce, ALL CAPS, etc). Only the "craft" states represent canonical output. */
import '../styles/global.css';
import FloatNav from '../components/FloatNav.astro';

const title = 'Anti-slop, demonstrated';
const description = 'Eight patterns that make interfaces look AI-generated. Toggle Craft it to watch ui-craft rewrite each one in place.';

const patterns = [
  { id: 'gradient-button',  num: '01', name: 'Gradient button + bounce',   rules: 'no-purple-cyan-gradient · no-bounce-easing · generic-cta' },
  { id: 'uniform-cards',    num: '02', name: 'Uniform 3-card feature grid', rules: 'uniform-card-grid · emoji-as-icons · colored-top-borders' },
  { id: 'allcaps-heading',  num: '03', name: 'ALL CAPS heading',            rules: 'all-caps-headings · wide-tracking-display' },
  { id: 'gradient-metric',  num: '04', name: 'Gradient text on a metric',   rules: 'gradient-text-on-hero-metrics · no-tabular-nums' },
  { id: 'glass-neon',       num: '05', name: 'Glassmorphism + neon',        rules: 'glassmorphism-decoration · decorative-glow · neon-box-shadow' },
  { id: 'gradient-blob',    num: '06', name: 'Decorative gradient blob',    rules: 'gradient-blobs · decorative-orbs · bouncing-decor' },
  { id: 'trend-pill',       num: '07', name: 'Colored pill on trend %',     rules: 'colored-pills-on-trend · stat-as-decoration' },
  { id: 'spinner-loading',  num: '08', name: 'Loading spinner + caps',      rules: 'generic-loading-spinners · skeleton-shape-mismatch' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="canonical" href={`https://skills.smoothui.dev${Astro.url.pathname}`} />
    <meta property="og:title" content={`${title} — UI Craft`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={`https://skills.smoothui.dev${Astro.url.pathname}`} />
    <meta property="og:site_name" content="UI Craft" />
    <meta property="og:image" content="https://skills.smoothui.dev/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — UI Craft`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://skills.smoothui.dev/og.png" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link href="https://cdn.jsdelivr.net/fontsource/fonts/geist-sans@latest/latin-400-normal.woff2" rel="preload" as="font" type="font/woff2" crossorigin />
    <link href="https://cdn.jsdelivr.net/fontsource/fonts/geist-mono@latest/latin-400-normal.woff2" rel="preload" as="font" type="font/woff2" crossorigin />
    <style>
      @font-face { font-family: 'Geist'; font-style: normal; font-weight: 400; font-display: swap; src: url('https://cdn.jsdelivr.net/fontsource/fonts/geist-sans@latest/latin-400-normal.woff2') format('woff2'); }
      @font-face { font-family: 'Geist'; font-style: normal; font-weight: 500; font-display: swap; src: url('https://cdn.jsdelivr.net/fontsource/fonts/geist-sans@latest/latin-500-normal.woff2') format('woff2'); }
      @font-face { font-family: 'Geist'; font-style: normal; font-weight: 600; font-display: swap; src: url('https://cdn.jsdelivr.net/fontsource/fonts/geist-sans@latest/latin-600-normal.woff2') format('woff2'); }
      @font-face { font-family: 'Geist'; font-style: normal; font-weight: 700; font-display: swap; src: url('https://cdn.jsdelivr.net/fontsource/fonts/geist-sans@latest/latin-700-normal.woff2') format('woff2'); }
      @font-face { font-family: 'Geist Mono'; font-style: normal; font-weight: 400; font-display: swap; src: url('https://cdn.jsdelivr.net/fontsource/fonts/geist-mono@latest/latin-400-normal.woff2') format('woff2'); }
    </style>
    <title>{title} — UI Craft</title>
  </head>
  <body
    data-craft="off"
    class="font-[family-name:var(--font-body)] text-[15px] leading-relaxed text-[var(--color-text)] bg-[var(--color-bg)]"
  >
    <a href="#gallery" class="absolute top-0 left-4 px-4 py-2 bg-blue-600 text-white font-medium text-sm rounded-b-md z-50 -translate-y-full focus:translate-y-0 transition-transform duration-200 ease-[var(--ease-out)]">Skip to gallery</a>

    <!-- Top bar -->
    <header class="sticky top-0 z-30 border-b border-[var(--color-border)] bg-[var(--color-bg)]/85 backdrop-blur">
      <div class="mx-auto max-w-[1200px] px-[clamp(1rem,3vw,2rem)] h-12 flex items-center justify-between gap-4">
        <a href="/" class="inline-flex items-center gap-2 text-[13px] font-medium tracking-tight">
          <img src="/icon.png" alt="" width="22" height="22" class="rounded-[6px]" />
          <span>UI&nbsp;Craft</span>
          <span class="text-[var(--color-text-secondary)] font-normal">/ anti-slop</span>
        </a>
        <div class="flex items-center gap-5 text-[12px]">
          <a href="/" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text)] focus-visible:text-[var(--color-text)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 rounded-sm transition-colors duration-150 ease-[var(--ease-out)]">Home</a>
          <a href="/docs" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text)] focus-visible:text-[var(--color-text)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 rounded-sm transition-colors duration-150 ease-[var(--ease-out)]">Docs</a>
          <a href="https://github.com/educlopez/ui-craft" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text)] focus-visible:text-[var(--color-text)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 rounded-sm transition-colors duration-150 ease-[var(--ease-out)]">GitHub&nbsp;&rarr;</a>
        </div>
      </div>
    </header>

    <div class="mx-auto max-w-[960px] px-[clamp(1rem,3vw,2rem)] py-12 md:py-16">

      <!-- Hero -->
      <header class="max-w-[60ch]">
        <p class="text-[11px] font-[family-name:var(--font-mono)] uppercase tracking-[0.12em] text-[oklch(55%_0.005_250)] mb-3">Interactive · 8 patterns</p>
        <h1 class="text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold tracking-[-0.02em] leading-[1.1] [text-wrap:balance]">Anti-slop, demonstrated.</h1>
        <p class="text-[var(--color-text-secondary)] mt-3 leading-relaxed max-w-[54ch]">
          Eight patterns that make interfaces look AI-generated.
          Flip the toggle to watch each one transform into the crafted version ui-craft writes instead.
        </p>
      </header>

      <!-- Sticky toggle bar -->
      <div class="toggle-wrap mt-10 mb-12 md:mb-16 md:sticky md:top-12 z-20 bg-[var(--color-bg)]/92 backdrop-blur border-b border-[var(--color-border)] py-4 -mx-[clamp(1rem,3vw,2rem)] px-[clamp(1rem,3vw,2rem)]">
        <div class="flex items-center justify-between gap-6 flex-wrap">
          <button
            type="button"
            class="craft-toggle"
            aria-pressed="false"
            aria-label="Toggle between slop and crafted states"
          >
            <span class="craft-toggle-track" aria-hidden="true">
              <span class="craft-toggle-thumb"></span>
            </span>
            <span class="craft-toggle-labels" aria-hidden="true">
              <span class="state-off">Slop</span>
              <span class="state-on">Crafted</span>
            </span>
          </button>
          <p class="stats text-[12px] text-[var(--color-text-secondary)] font-[family-name:var(--font-mono)] tabular-nums">
            <span>8 patterns</span>
            <span class="stats-sep">·</span>
            <span data-detected>8</span> <span>detected</span>
            <span class="stats-sep">·</span>
            <span data-fixed>0</span> <span>fixed</span>
          </p>
        </div>
      </div>

      <!-- Gallery -->
      <div id="gallery" class="grid md:grid-cols-2 gap-12 md:gap-10">

        <!-- 01 · Gradient button + bounce -->
        <section class="pattern" data-pattern="gradient-button" style="--stagger:0ms">
          <header class="pattern-head">
            <span class="pattern-num">01</span>
            <h2 class="pattern-title">Gradient button + bounce</h2>
          </header>
          <div class="demo-area demo-area--center">
            <button type="button" class="demo-btn-01" tabindex="0">
              <span class="btn-text">See pricing details</span>
              <svg class="btn-arrow" viewBox="0 0 12 12" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2.5 6h7" />
                <path d="M6.5 3l3 3-3 3" />
              </svg>
            </button>
          </div>
          <footer class="pattern-meta">
            <code class="rule">no-purple-cyan-gradient · no-bounce-easing · generic-cta</code>
            <p class="caption">Three rules fire. <a href="/docs/ui-craft-detect">See all 33 in the detector →</a></p>
          </footer>
        </section>

        <!-- 02 · Uniform 3-card grid -->
        <section class="pattern" data-pattern="uniform-cards" style="--stagger:40ms">
          <header class="pattern-head">
            <span class="pattern-num">02</span>
            <h2 class="pattern-title">Uniform 3-card grid</h2>
          </header>
          <div class="demo-area">
            <div class="cards-grid">
              <!-- Card A: Revenue — same feature, slop uses emoji+lorem treatment, craft uses sparkline+metric -->
              <div class="mini-card mini-card--a">
                <!-- SLOP view -->
                <div class="mini-slop label-off">
                  <span class="emoji-icon">🚀</span>
                  <h3 class="mini-card-title">Revenue</h3>
                  <p class="mini-card-body">Lorem ipsum dolor sit amet consectetur adipiscing.</p>
                </div>
                <!-- CRAFT view -->
                <div class="mini-craft label-on">
                  <svg class="mini-spark" viewBox="0 0 120 32" width="120" height="32" preserveAspectRatio="none" aria-hidden="true">
                    <defs>
                      <linearGradient id="spark-fill-a" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="oklch(62% 0.15 250)" stop-opacity="0.28" />
                        <stop offset="100%" stop-color="oklch(62% 0.15 250)" stop-opacity="0" />
                      </linearGradient>
                      <linearGradient id="spark-stroke-a" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="oklch(62% 0.15 250)" stop-opacity="0.55" />
                        <stop offset="100%" stop-color="oklch(62% 0.15 250)" stop-opacity="1" />
                      </linearGradient>
                    </defs>
                    <line x1="0" y1="30" x2="120" y2="30" stroke="oklch(92% 0.005 250)" stroke-width="1" stroke-dasharray="2 3" />
                    <path d="M0,26 Q8,24 14,25 T28,21 Q34,23 40,19 T52,14 Q60,17 68,12 T82,9 Q90,11 96,6 T106,6 L106,32 L0,32 Z" fill="url(#spark-fill-a)" />
                    <path d="M0,26 Q8,24 14,25 T28,21 Q34,23 40,19 T52,14 Q60,17 68,12 T82,9 Q90,11 96,6 T106,6" fill="none" stroke="url(#spark-stroke-a)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    <circle cx="106" cy="6" r="2.5" fill="oklch(62% 0.15 250)" />
                    <circle cx="106" cy="6" r="4.5" fill="oklch(62% 0.15 250)" fill-opacity="0.18" />
                  </svg>
                  <p class="mini-metric-big"><span class="tnum">$12,480</span></p>
                  <p class="mini-metric-label">Revenue · last 7 days</p>
                  <p class="mini-metric-trend"><span class="tnum">+12.5%</span> from last week</p>
                </div>
              </div>

              <!-- Card C: Customer feedback — same feature, slop uses emoji+lorem treatment, craft uses pullquote+avatar -->
              <div class="mini-card mini-card--c">
                <!-- SLOP view -->
                <div class="mini-slop label-off">
                  <span class="emoji-icon">⚡</span>
                  <h3 class="mini-card-title">Customer feedback</h3>
                  <p class="mini-card-body">Lorem ipsum dolor sit amet consectetur adipiscing.</p>
                </div>
                <!-- CRAFT view -->
                <div class="mini-craft label-on">
                  <blockquote class="mini-pullquote">
                    <p>It stopped looking like an AI wrote it — even my designer asked who made it.</p>
                  </blockquote>
                  <div class="mini-avatar-row">
                    <img
                      src="/avatars/avatar-alex.jpg"
                      alt="Alex Chen"
                      width="28"
                      height="28"
                      class="avatar-img avatar-img--sm"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="mini-avatar-meta">
                      <span class="mini-avatar-name">Alex Chen</span>
                      <span class="mini-avatar-role">Frontend lead</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <footer class="pattern-meta">
            <code class="rule">uniform-card-grid · emoji-as-icons · colored-top-borders</code>
            <p class="caption">Identical cards become distinct shapes.</p>
          </footer>
        </section>

        <!-- 03 · ALL CAPS heading -->
        <section class="pattern" data-pattern="allcaps-heading" style="--stagger:80ms">
          <header class="pattern-head">
            <span class="pattern-num">03</span>
            <h2 class="pattern-title">ALL CAPS heading</h2>
          </header>
          <div class="demo-area demo-area--left">
            <div class="heading-demo">
              <p class="demo-eyebrow label-on"><span class="demo-eyebrow-label">Features</span><span class="demo-eyebrow-sep">·</span><span class="demo-eyebrow-count tnum">04</span></p>
              <h3 class="demo-h2">Features</h3>
              <p class="demo-sub">What you get.</p>
            </div>
          </div>
          <footer class="pattern-meta">
            <code class="rule">all-caps-headings · wide-tracking-display</code>
            <p class="caption">Uppercase tracking reads as a label, not a section heading.</p>
          </footer>
        </section>

        <!-- 04 · Gradient metric -->
        <section class="pattern" data-pattern="gradient-metric" style="--stagger:120ms">
          <header class="pattern-head">
            <span class="pattern-num">04</span>
            <h2 class="pattern-title">Gradient metric text</h2>
          </header>
          <div class="demo-area demo-area--left">
            <div class="metric-demo">
              <div class="metric-row">
                <svg class="metric-spark label-on" viewBox="0 0 80 40" width="80" height="40" preserveAspectRatio="none" aria-hidden="true">
                  <defs>
                    <linearGradient id="spark-fill-b" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="oklch(62% 0.15 250)" stop-opacity="0.30" />
                      <stop offset="100%" stop-color="oklch(62% 0.15 250)" stop-opacity="0" />
                    </linearGradient>
                    <linearGradient id="spark-stroke-b" x1="0" y1="0" x2="1" y2="0">
                      <stop offset="0%" stop-color="oklch(62% 0.15 250)" stop-opacity="0.45" />
                      <stop offset="100%" stop-color="oklch(62% 0.15 250)" stop-opacity="1" />
                    </linearGradient>
                  </defs>
                  <path d="M0,34 Q8,33 14,34 T24,33 Q30,31 34,28 T46,20 Q52,14 58,10 T66,7 L66,40 L0,40 Z" fill="url(#spark-fill-b)" />
                  <path d="M0,34 Q8,33 14,34 T24,33 Q30,31 34,28 T46,20 Q52,14 58,10 T66,7" fill="none" stroke="url(#spark-stroke-b)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
                  <circle cx="66" cy="7" r="2.75" fill="oklch(62% 0.15 250)" />
                  <circle cx="66" cy="7" r="5" fill="oklch(62% 0.15 250)" fill-opacity="0.16" />
                </svg>
                <div class="metric-big tnum">+324%</div>
              </div>
              <p class="metric-sub label-on">
                <span class="metric-sub-main">vs last quarter</span>
                <span class="metric-sub-sep">·</span>
                <span class="tnum metric-sub-range">Q3 &rarr; Q4</span>
              </p>
              <p class="metric-context label-on">Driven by retention cohort changes in enterprise.</p>
            </div>
          </div>
          <footer class="pattern-meta">
            <code class="rule">gradient-text-on-hero-metrics · no-tabular-nums</code>
            <p class="caption">Gradient fill makes numbers harder to read, not more impressive.</p>
          </footer>
        </section>

        <!-- 05 · Glass + neon -->
        <section class="pattern" data-pattern="glass-neon" style="--stagger:160ms">
          <header class="pattern-head">
            <span class="pattern-num">05</span>
            <h2 class="pattern-title">Glassmorphism + neon</h2>
          </header>
          <div class="demo-area demo-area--center glass-stage">
            <div class="glass-bg" aria-hidden="true"></div>
            <div class="glass-card">
              <!-- SAME content in both states — slop/craft differ only in treatment -->
              <div class="glass-inner">
                <div class="glass-craft-head">
                  <img
                    src="/avatars/avatar-jordan.jpg"
                    alt="Jordan Rivera"
                    width="40"
                    height="40"
                    class="avatar-img avatar-img--md"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="glass-craft-id">
                    <p class="glass-craft-name">Jordan Rivera</p>
                    <p class="glass-craft-role">Design Engineer</p>
                    <p class="glass-craft-meta"><span class="glass-dot" aria-hidden="true"></span>Online<span class="glass-craft-sep">·</span>active <span class="tnum">2m</span> ago</p>
                  </div>
                </div>
                <p class="glass-craft-body">Reviewed the new pricing page.</p>
                <p class="glass-craft-stats"><span class="tnum">3</span> comments<span class="glass-craft-sep">·</span><span class="tnum">2</span> mentions<span class="glass-craft-sep">·</span><span class="tnum">15</span> min read</p>
                <div class="glass-craft-divider" aria-hidden="true"></div>
                <p class="glass-craft-foot">updated <span class="tnum">4:15 PM</span><span class="glass-craft-sep">·</span>Project Aurora</p>
              </div>
            </div>
          </div>
          <footer class="pattern-meta">
            <code class="rule">glassmorphism-decoration · decorative-glow · neon-box-shadow</code>
            <p class="caption">Backdrop blur and cyan glow read as decoration, not depth.</p>
          </footer>
        </section>

        <!-- 06 · Decorative blob -->
        <section class="pattern" data-pattern="gradient-blob" style="--stagger:200ms">
          <header class="pattern-head">
            <span class="pattern-num">06</span>
            <h2 class="pattern-title">Decorative gradient blobs</h2>
          </header>
          <div class="demo-area demo-area--center blob-stage">
            <div class="blob blob--pink" aria-hidden="true"></div>
            <div class="blob blob--blue" aria-hidden="true"></div>
            <div class="blob-content">
              <span class="blob-rule" aria-hidden="true"></span>
              <p class="blob-eyebrow">Essay · 02</p>
              <p class="blob-title">Typography, given the room it needs.</p>
              <p class="blob-sub blob-quote">Restraint is not the absence of style — it is the evidence that a designer made every call on purpose, and none of them were decoration.</p>
            </div>
          </div>
          <footer class="pattern-meta">
            <code class="rule">gradient-blobs · decorative-orbs · bouncing-decor</code>
            <p class="caption">Blobs exist because the layout wasn't good enough without them.</p>
          </footer>
        </section>

        <!-- 07 · Trend pill -->
        <section class="pattern" data-pattern="trend-pill" style="--stagger:240ms">
          <header class="pattern-head">
            <span class="pattern-num">07</span>
            <h2 class="pattern-title">Colored trend pill</h2>
          </header>
          <div class="demo-area demo-area--left">
            <!-- SLOP: same Revenue $12,480 + 12.5% trend — rendered with gradient text + colored pill + glow -->
            <div class="kpi-slop label-off" aria-hidden="true">
              <div class="kpi-slop-head">
                <span class="kpi-slop-label">Revenue</span>
                <span class="kpi-slop-badge">+12.5%</span>
              </div>
              <p class="kpi-slop-value"><span class="tnum">$12,480</span></p>
              <p class="kpi-slop-context">from last month</p>
            </div>
            <!-- CRAFT: dub-style KPI card with embedded sparkline -->
            <div class="kpi-card label-on">
              <div class="kpi-head">
                <span class="kpi-label">Revenue</span>
                <button type="button" class="kpi-filter" tabindex="-1" aria-hidden="true">
                  Last 7 days
                  <svg viewBox="0 0 10 6" width="8" height="5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 1l4 4 4-4" /></svg>
                </button>
              </div>
              <div class="kpi-body">
                <p class="kpi-value"><span class="tnum">$12,480</span></p>
                <svg class="kpi-spark" viewBox="0 0 140 48" width="140" height="48" preserveAspectRatio="none" aria-hidden="true">
                  <defs>
                    <linearGradient id="spark-fill-d" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="oklch(62% 0.15 250)" stop-opacity="0.32" />
                      <stop offset="100%" stop-color="oklch(62% 0.15 250)" stop-opacity="0" />
                    </linearGradient>
                    <linearGradient id="spark-stroke-d" x1="0" y1="0" x2="1" y2="0">
                      <stop offset="0%" stop-color="oklch(62% 0.15 250)" stop-opacity="0.55" />
                      <stop offset="100%" stop-color="oklch(62% 0.15 250)" stop-opacity="1" />
                    </linearGradient>
                  </defs>
                  <path d="M0,34 Q10,31 20,29 T38,27 Q46,30 54,32 T72,28 Q82,23 92,19 T108,14 Q114,11 118,10 T122,9 L122,48 L0,48 Z" fill="url(#spark-fill-d)" />
                  <path d="M0,34 Q10,31 20,29 T38,27 Q46,30 54,32 T72,28 Q82,23 92,19 T108,14 Q114,11 118,10 T122,9" fill="none" stroke="url(#spark-stroke-d)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
                  <circle cx="122" cy="9" r="3" fill="oklch(62% 0.15 250)" />
                  <circle cx="122" cy="9" r="5.5" fill="oklch(62% 0.15 250)" fill-opacity="0.18" />
                </svg>
              </div>
              <p class="kpi-trend">
                <svg class="trend-triangle" viewBox="0 0 8 8" width="8" height="8" aria-hidden="true">
                  <path d="M4 1 L7.5 6.5 L0.5 6.5 Z" fill="currentColor" />
                </svg>
                <span class="kpi-trend-pct tnum">12.5%</span>
                <span class="kpi-trend-context">from last month</span>
              </p>
              <div class="kpi-divider" aria-hidden="true"></div>
              <p class="kpi-foot">Last updated <span class="tnum">2</span> minutes ago</p>
            </div>
          </div>
          <footer class="pattern-meta">
            <code class="rule">colored-pills-on-trend · stat-as-decoration</code>
            <p class="caption">A green pill adds color, not information. Typography carries it.</p>
          </footer>
        </section>

        <!-- 08 · Loading spinner -->
