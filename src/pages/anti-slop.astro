    </div>

    <style is:global>
      /* ============================================================
         ANTI-SLOP GALLERY — STATE SWITCH
         Base transitions live on the elements.
         Slop / Craft properties live on [data-craft="off"] / ="on"
         ============================================================ */

      body[data-craft] { overflow-x: hidden; }

      /* Label show/hide — both states live in DOM, visibility per toggle */
      [data-craft="off"] .label-on, [data-craft="off"] .label-on-inline { display: none; }
      [data-craft="on"]  .label-off, [data-craft="on"]  .label-off-inline { display: none; }

      /* ---------- Craft Toggle ---------- */
      .craft-toggle {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        background: transparent;
        border: 0;
        padding: 0;
        cursor: pointer;
        font: inherit;
        color: var(--color-text);
      }
      .craft-toggle:focus-visible { outline: 2px solid oklch(0.458 0.305 268.13); outline-offset: 4px; border-radius: 8px; }
      .craft-toggle-track {
        position: relative;
        width: 56px;
        height: 30px;
        border-radius: 999px;
        background: oklch(92% 0.005 250);
        border: 1px solid var(--color-border);
        transition: background 300ms var(--ease-out);
        flex-shrink: 0;
      }
      .craft-toggle-thumb {
        position: absolute;
        top: 2px;
        left: 2px;
        width: 24px;
        height: 24px;
        border-radius: 999px;
        background: var(--color-bg);
        box-shadow: 0 1px 2px oklch(20% 0.02 250 / 0.12), 0 2px 6px oklch(20% 0.02 250 / 0.06);
        transition: transform 300ms var(--ease-out);
      }
      [data-craft="on"] .craft-toggle-track { background: oklch(0.458 0.305 268.13); }
      [data-craft="on"] .craft-toggle-thumb { transform: translateX(26px); }

      .craft-toggle-labels {
        display: inline-flex;
        align-items: baseline;
        gap: 6px;
        font-size: 14px;
        font-weight: 500;
      }
      .craft-toggle-labels .state-off { color: var(--color-text); }
      .craft-toggle-labels .state-on { color: var(--color-text-secondary); }
      [data-craft="on"] .craft-toggle-labels .state-off { color: var(--color-text-secondary); }
      [data-craft="on"] .craft-toggle-labels .state-on  { color: var(--color-text); }

      .stats-sep { color: oklch(75% 0.005 250); padding: 0 4px; }

      /* ---------- Pattern chrome ---------- */
      .pattern {
        display: flex;
        flex-direction: column;
        gap: 14px;
        height: 100%;
      }
      .pattern-head {
        display: flex;
        align-items: baseline;
        gap: 10px;
      }
      .pattern-num {
        font-family: var(--font-mono);
        font-size: 11px;
        color: oklch(60% 0.005 250);
        letter-spacing: 0.04em;
      }
      .pattern-title {
        font-size: 14px;
        font-weight: 500;
        color: var(--color-text);
        letter-spacing: -0.005em;
      }
      .demo-area {
        position: relative;
        flex: 1;
        min-height: 440px;
        border: 1px solid var(--color-border);
        border-radius: 10px;
        background: var(--color-bg);
        padding: 36px 32px;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        overflow: hidden;
      }
      .demo-area--center { justify-content: center; text-align: center; }
      .demo-area--left   { justify-content: flex-start; align-items: center; }
      @media (max-width: 640px) {
        .demo-area { min-height: 360px; padding: 28px 22px; }
      }

      .pattern-meta { display: flex; flex-direction: column; gap: 6px; }
      .pattern-meta .rule {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 11px;
        background: var(--color-code-bg);
        border: 1px solid var(--color-border);
        padding: 3px 8px;
        border-radius: 4px;
        color: var(--color-text);
        line-height: 1.6;
        width: fit-content;
        max-width: 100%;
        overflow-wrap: anywhere;
      }
      .pattern-meta .caption {
        font-size: 12.5px;
        color: var(--color-text-secondary);
        line-height: 1.5;
      }
      .pattern-meta .caption a {
        color: var(--color-text);
        text-decoration: underline;
        text-decoration-color: var(--color-border);
        text-underline-offset: 3px;
        transition: text-decoration-color 0.15s var(--ease-out);
      }
      .pattern-meta .caption a:hover { text-decoration-color: var(--color-text-secondary); }

      /* Common staggered transition base for state-aware elements */
      .demo-btn-01,
      .mini-card,
      .demo-h2,
      .metric-big,
      .glass-card,
      .blob,
      .blob-content,
      .kpi-slop,
      .kpi-card,
      .slop-loader,
      .craft-skeleton {
        transition:
          background 400ms var(--ease-out),
          background-color 400ms var(--ease-out),
          color 400ms var(--ease-out),
          box-shadow 400ms var(--ease-out),
          border-radius 400ms var(--ease-out),
          border 400ms var(--ease-out),
          transform 400ms var(--ease-out),
          letter-spacing 400ms var(--ease-out),
          font-weight 400ms var(--ease-out),
          opacity 400ms var(--ease-out),
          filter 400ms var(--ease-out);
        transition-delay: var(--stagger, 0ms);
      }

      /* ============================================================
         01 · Gradient button + bounce
         ============================================================ */
      .demo-btn-01 {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 12px 24px;
        font-size: 14px;
        font-weight: 600;
        color: white;
        border: 0;
        cursor: pointer;
      }
      .demo-btn-01:focus-visible { outline: 2px solid oklch(0.458 0.305 268.13); outline-offset: 3px; }
      .demo-btn-01 .btn-arrow { transition: transform 180ms var(--ease-out); }

      [data-craft="off"] .demo-btn-01 {
        background: linear-gradient(135deg, #8b5cf6 0%, #06b6d4 100%);
        box-shadow: 0 8px 32px rgba(139, 92, 246, 0.45);
        border-radius: 999px;
        transition-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      [data-craft="off"] .demo-btn-01:hover { transform: translateY(-4px); }

      [data-craft="on"] .demo-btn-01 {
        background: oklch(62% 0.15 250);
        color: oklch(99% 0.002 250);
        box-shadow:
          inset 0 1px 0 oklch(100% 0 0 / 0.12),
          0 1px 2px oklch(20% 0.02 250 / 0.08),
          0 4px 10px -4px oklch(62% 0.15 250 / 0.40);
        border-radius: 8px;
        padding: 10px 16px;
        font-size: 13px;
        font-weight: 500;
        letter-spacing: -0.01em;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "ss01";
        transition-timing-function: var(--ease-out);
        transition-duration: 180ms;
      }
      [data-craft="on"] .demo-btn-01:hover {
        transform: translateY(-1px);
        box-shadow:
          inset 0 1px 0 oklch(100% 0 0 / 0.14),
          0 2px 4px oklch(20% 0.02 250 / 0.10),
          0 10px 24px -6px oklch(62% 0.15 250 / 0.50);
      }
      [data-craft="on"] .demo-btn-01:hover .btn-arrow { transform: translateX(2px); }
      [data-craft="on"] .demo-btn-01:active {
        transform: translateY(0);
        box-shadow:
          inset 0 1px 1px oklch(20% 0.08 250 / 0.18),
          0 1px 1px oklch(20% 0.02 250 / 0.08);
      }

      /* ============================================================
         02 · Card grid — asymmetric, each card distinct by purpose
         ============================================================ */
      .cards-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        width: 100%;
      }
      @media (max-width: 640px) {
        .cards-grid { grid-template-columns: 1fr; }
      }
      .mini-card {
        padding: 14px;
        background: var(--color-bg);
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-height: 136px;
      }
      .emoji-icon { font-size: 20px; line-height: 1; display: inline-block; margin-bottom: 6px; }
      .mini-card-title { font-size: 13px; font-weight: 500; color: var(--color-text); letter-spacing: -0.005em; }
      .mini-card-body  { font-size: 12px; color: var(--color-text-secondary); line-height: 1.45; }

      .mini-slop, .mini-craft { display: flex; flex-direction: column; gap: 6px; }

      /* Craft card A — metric/sparkline */
      .mini-spark { color: oklch(62% 0.15 250); display: block; margin-bottom: 4px; width: 100%; height: auto; max-width: 140px; }
      .mini-metric-big {
        font-size: 22px;
        font-weight: 500;
        color: var(--color-text);
        letter-spacing: -0.02em;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "ss01", "tnum";
        line-height: 1.05;
      }
      .mini-metric-label { font-size: 11px; color: var(--color-text-secondary); font-family: var(--font-mono); letter-spacing: 0.02em; }
      .mini-metric-trend { font-size: 11px; color: var(--color-text-secondary); line-height: 1.4; }
      .mini-metric-trend .tnum { color: oklch(52% 0.13 155); font-variant-numeric: tabular-nums; font-weight: 500; }

      /* Craft card B — icon + title + caption */
      .mini-icon { color: oklch(62% 0.15 250); margin-bottom: 4px; }

      /* Craft card C — pull-quote + avatar row */
      .mini-pullquote { margin: 0; }
      .mini-pullquote p {
        font-size: 12.5px;
        font-style: italic;
        color: var(--color-text);
        line-height: 1.45;
        letter-spacing: -0.005em;
        text-wrap: pretty;
      }
      .mini-avatar-row { display: flex; align-items: center; gap: 8px; margin-top: 6px; }
      .mini-avatar-meta { display: flex; flex-direction: column; line-height: 1.25; }
      .mini-avatar-name { font-size: 11.5px; font-weight: 500; color: var(--color-text); letter-spacing: -0.005em; }
      .mini-avatar-role { font-size: 10.5px; color: var(--color-text-secondary); font-family: var(--font-mono); }

      /* Real-photo avatars (shared across patterns) */
      .avatar-img {
        display: block;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid oklch(92% 0.005 250);
        background: oklch(96% 0.003 250);
        flex-shrink: 0;
      }
      .avatar-img--sm { width: 28px; height: 28px; }
      .avatar-img--md { width: 40px; height: 40px; }

      /* Slop: all identical, colored top border, emoji visible */
      [data-craft="off"] .mini-card {
        border: 1px solid var(--color-border);
        border-top: 3px solid hsl(270 70% 60%);
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(139, 92, 246, 0.08);
      }
      [data-craft="off"] .mini-craft { display: none; }
      [data-craft="off"] .mini-slop { display: flex; }

      /* Craft: asymmetric grid, hairline border, varied radii, layered shadow */
      [data-craft="on"] .cards-grid {
        grid-template-columns: 1.1fr 1fr;
      }
      @media (max-width: 640px) {
        [data-craft="on"] .cards-grid { grid-template-columns: 1fr; }
      }
      [data-craft="on"] .mini-card {
        border: 1px solid oklch(92% 0.005 250);
        box-shadow:
          0 1px 2px oklch(20% 0.02 250 / 0.04),
          0 4px 12px -4px oklch(20% 0.02 250 / 0.05);
      }
      [data-craft="on"] .mini-slop { display: none; }
      [data-craft="on"] .mini-craft { display: flex; }
      [data-craft="on"] .mini-card--a { border-radius: 12px; }
      [data-craft="on"] .mini-card--b { border-radius: 8px; }
      [data-craft="on"] .mini-card--c { border-radius: 10px; }

      /* ============================================================
         03 · ALL CAPS heading — editorial block
         ============================================================ */
      .heading-demo { width: 100%; }
      .demo-h2 {
        margin: 0;
        color: var(--color-text);
        line-height: 1.1;
      }
      .demo-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--color-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 12px;
      }
      .demo-eyebrow-label { color: var(--color-text-secondary); }
      .demo-eyebrow-sep { color: oklch(75% 0.005 250); }
      .demo-eyebrow-count { color: var(--color-text); font-variant-numeric: tabular-nums; }
      .demo-sub {
        margin-top: 10px;
        font-size: 14px;
        color: var(--color-text-secondary);
        line-height: 1.55;
        max-width: 46ch;
        text-wrap: pretty;
      }

      [data-craft="off"] .heading-demo { text-align: center; }
      [data-craft="off"] .demo-h2 {
        font-size: 24px;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }
      [data-craft="off"] .demo-sub {
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-top: 14px;
        color: var(--color-text-secondary);
        text-align: center;
      }
      [data-craft="on"] .heading-demo { text-align: left; }
      [data-craft="on"] .demo-h2 {
        font-size: clamp(28px, 4.5vw, 40px);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.08;
        text-wrap: balance;
        max-width: 18ch;
      }

      /* ============================================================
         04 · Gradient metric text — crafted hero number
         ============================================================ */
      .metric-demo { display: flex; flex-direction: column; align-items: flex-start; }
      .metric-row {
        display: inline-flex;
        align-items: baseline;
        gap: 10px;
      }
      .metric-big {
        font-size: 56px;
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.03em;
      }
      .metric-spark { color: oklch(62% 0.15 250); align-self: flex-end; margin-bottom: 6px; }
      .metric-sub {
        margin-top: 10px;
        font-size: 13px;
        color: var(--color-text-secondary);
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }
      .metric-sub-sep { color: oklch(75% 0.005 250); }
      .metric-sub-range { font-family: var(--font-mono); font-size: 12px; color: var(--color-text); font-variant-numeric: tabular-nums; }
      .metric-context { margin-top: 4px; font-size: 12px; color: oklch(55% 0.005 250); line-height: 1.5; max-width: 38ch; }

      [data-craft="off"] .metric-big {
        background: linear-gradient(to right, #ec4899, #8b5cf6);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
      }
      [data-craft="on"] .metric-big {
        color: var(--color-text);
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum", "ss01";
        font-weight: 500;
        font-size: 64px;
        letter-spacing: -0.035em;
      }

      /* ============================================================
         05 · Glass + neon
         ============================================================ */
      .glass-stage {
        padding: 0;
      }
      .glass-bg {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, oklch(30% 0.08 280) 0%, oklch(22% 0.06 230) 100%);
        opacity: 1;
        transition: opacity 400ms var(--ease-out);
      }
      [data-craft="on"] .glass-bg { opacity: 0; }

      .glass-card {
        position: relative;
        z-index: 1;
        padding: 18px 20px;
        width: calc(100% - 40px);
        max-width: 360px;
        text-align: left;
      }

      .glass-inner { display: flex; flex-direction: column; gap: 10px; }

      /* SLOP: glassmorphism panel with cyan neon glow + gradient name */
      [data-craft="off"] .glass-card {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
