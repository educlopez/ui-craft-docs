      <!-- Footer CTA -->
      <footer class="page-cta mt-24 md:mt-32 pt-10 border-t border-[var(--color-border)]">
        <h2 class="text-[clamp(1.25rem,2.5vw,1.75rem)] font-medium tracking-tight [text-wrap:balance]">This page was dogfooded.</h2>
        <p class="text-[var(--color-text-secondary)] mt-3 max-w-[56ch] leading-relaxed">
          The landing you're on runs through <code class="inline-code">ui-craft-detect</code> on every push. Zero findings.
